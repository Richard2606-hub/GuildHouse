# GuildHouse Environment Variables
# Copy this to .env and fill in your values

# Gemini AI API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Fireworks AI API Key
FIREWORKS_API_KEY=your_fireworks_api_key_here

# Provider Configuration (gemini or fireworks)
# LOCAL_PROVIDER=fireworks
# ESCALATION_PROVIDER=gemini
# JUDGE_PROVIDER=fireworks
# TOOL_PROVIDER=gemini

# Model Configuration (optional — defaults are set in config.py)
# LOCAL_MODEL=accounts/fireworks/models/gemma2-9b-it
# ESCALATION_MODEL=gemini-3.1-flash-lite

# Confidence threshold for escalation (0.0 - 1.0)
# ESCALATION_THRESHOLD=0.7
